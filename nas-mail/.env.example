# Copy to .env and fill in. Do NOT commit .env.

# ECOUNT mail server (confirm exact host/port with ECOUNT support)
IMAP_HOST=imap.ecounterp.com
IMAP_PORT=993
SMTP_HOST=smtp.ecounterp.com
SMTP_PORT=587

# Lock CORS to your groupware origin once deployed
ALLOWED_ORIGIN=https://jeongdamgudo-pro.pages.dev

# 'strict' rejects bad TLS certificates; use 'lax' only for testing
IMAP_TLS=strict
SMTP_TLS=strict
